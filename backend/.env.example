# ─── Server ──────────────────────────────────────────
NODE_ENV=development
PORT=5001

# Comma-separated list of origins that may call the API.
# Use "*" for development only. Examples:
#   CORS_ORIGINS=http://localhost:5173,https://artloop.app
CORS_ORIGINS=http://localhost:5173

# ─── Admin auth ──────────────────────────────────────
# Long, opaque secret. Sent by the admin panel as `x-admin-token` header.
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ADMIN_TOKEN=replace-with-a-long-random-string

# ─── Business rules ──────────────────────────────────
# Amount (USD) added to the original's market value per print sold.
PRINT_BID_INCREMENT=125
# Maximum size, in MB, for the JSON body (covers base64 image uploads).
MAX_BODY_MB=8

# ─── Firebase ────────────────────────────────────────
# In production paste the full service-account JSON in this single env var.
# In local dev leave it empty and place the file at backend/serviceAccount.json.
# FIREBASE_CONFIG={"type":"service_account", ...}
